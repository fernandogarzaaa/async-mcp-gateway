# async-mcp-gateway environment template
#
# Copy this file to `.env` for local development. Keep real `.env` files out of
# git. Values below are safe examples and must be replaced before production use.

# Runtime environment label consumed by platform tooling and deployment policy.
# Allowed values: development, staging, production.
APP_ENV=development

# Public application name exposed in FastAPI metadata and logs.
APP_NAME=multi-tenant-ai-gateway

# Standard library logging threshold.
# Recommended values: DEBUG for local development, INFO for production.
LOG_LEVEL=INFO

# Redis connection string for token-bucket rate limiting.
# REDIS_URL is the platform-friendly alias; REDIS_URI is the current Pydantic
# Settings field consumed by app.core.config.Settings.
REDIS_URL=redis://localhost:6379/0
REDIS_URI=redis://localhost:6379/0

# Gateway request timeout in seconds for provider calls.
# GATEWAY_TIMEOUT_SECONDS is the operational alias; REQUEST_TIMEOUT_SECONDS is
# the canonical Settings field currently parsed by Pydantic.
GATEWAY_TIMEOUT_SECONDS=30
REQUEST_TIMEOUT_SECONDS=30

# Upstream streaming connection timeout in seconds.
STREAM_CONNECT_TIMEOUT_SECONDS=10

# Provider failover grace budget in milliseconds. A value of 100 keeps failover
# tight while allowing transient upstream response handling.
FAILOVER_BUDGET_MS=100

# Number of trailing SSE bytes retained for incremental regex scanning across
# chunk boundaries.
SSE_SCAN_TAIL_BYTES=512

# Default MCP process idle time-to-live in seconds. The supervisor schemas use
# this as MCP_PROCESS_TTL_SECONDS in deployment manifests; individual MCP server
# configs can override idle_ttl_seconds.
MCP_PROCESS_TTL_SECONDS=300

# OpenAI provider API key. Do not commit real keys.
# OPENAI_API_KEY is the common deployment alias. OPENAI__API_KEY is the nested
# Pydantic Settings key for Settings.openai.api_key.
OPENAI_API_KEY=sk-replace-with-openai-key
OPENAI__API_KEY=sk-replace-with-openai-key
OPENAI__BASE_URL=https://api.openai.com
OPENAI__CHAT_PATH=/v1/chat/completions
OPENAI__STREAM_PATH=/v1/chat/completions
OPENAI__DEFAULT_MODEL=gpt-4o-mini

# Anthropic provider API key. Do not commit real keys.
# ANTHROPIC_API_KEY is the common deployment alias. ANTHROPIC__API_KEY is the
# nested Pydantic Settings key for Settings.anthropic.api_key.
ANTHROPIC_API_KEY=sk-ant-replace-with-anthropic-key
ANTHROPIC__API_KEY=sk-ant-replace-with-anthropic-key
ANTHROPIC__BASE_URL=https://api.anthropic.com
ANTHROPIC__CHAT_PATH=/v1/messages
ANTHROPIC__STREAM_PATH=/v1/messages
ANTHROPIC__DEFAULT_MODEL=claude-3-5-haiku-latest

# Local fallback provider endpoint. For Docker Compose on Windows/macOS, use
# http://host.docker.internal:3000 when the fallback proxy runs on the host.
LOCAL__API_KEY=local-development-token
LOCAL__BASE_URL=http://127.0.0.1:3000
LOCAL__CHAT_PATH=/v1/chat/completions
LOCAL__STREAM_PATH=/v1/chat/completions
LOCAL__DEFAULT_MODEL=local-fallback

# Mock tenant credentials for local validation. The code ships with two in-memory
# tenants: tenant-alpha and tenant-beta. Replace this registry with a secure
# backing store before production.
TENANT_ALPHA_ID=tenant-alpha
TENANT_ALPHA_BEARER_TOKEN=alpha-secret-token
TENANT_ALPHA_RPM_LIMIT=120
TENANT_ALPHA_TPM_LIMIT=120000
TENANT_ALPHA_PROVIDER_PREFERENCE=openai,anthropic,local

TENANT_BETA_ID=tenant-beta
TENANT_BETA_BEARER_TOKEN=beta-secret-token
TENANT_BETA_RPM_LIMIT=60
TENANT_BETA_TPM_LIMIT=60000
TENANT_BETA_PROVIDER_PREFERENCE=anthropic,openai,local

# CORS origin list. The current Settings layer defaults to ["*"]. In production,
# restrict this to trusted UI origins at the ingress layer or by extending
# Settings.allowed_origins.
ALLOWED_ORIGINS=*

